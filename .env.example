# ngdai Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────
# Railway: set DATABASE_URL in Railway dashboard (auto-provided by Postgres plugin)
# Local: use NGDAI__DATABASE__URL or DATABASE_URL
DATABASE_URL=postgresql://ngdai:ngdai@localhost:5432/ngdai

# ── Redis ─────────────────────────────────────────────────
# Railway: set REDIS_URL in Railway dashboard (auto-provided by Redis plugin)
REDIS_URL=redis://localhost:6379/0

# ── Anthropic API ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Application ───────────────────────────────────────────
NGDAI_ENV=development
NGDAI_DEBUG=true
NGDAI_DATA_PATH=./data

# Railway sets PORT automatically - do not set manually on Railway
# PORT=8000
