# ngdai Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://ngdai:ngdai@localhost:5432/ngdai

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Application
NGDAI_ENV=development
NGDAI_DEBUG=true
NGDAI_DATA_PATH=./data
